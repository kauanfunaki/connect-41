generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN // acesso a todos os tenants (suporte 41 Tech)
  ADMIN // todo o tenant: setores, usuários, config
  SECTOR_ADMIN // seu(s) setor(es): CRUD + handoffs
  SECTOR_USER // seu(s) setor(es): leitura + atividades
  READONLY // todos os setores, somente leitura (Diretoria)
}

enum ManagementMode {
  MANAGED // frente 1: 41 Tech administra o CRM pelo cliente (cobrança mensal fixa)
  SELF_SERVICE // frente 2: cliente administra o próprio CRM (cobrança por usuário)
}

enum BillingType {
  FLAT_MONTHLY // valor fixo mensal — usado em planos MANAGED
  PER_USER_MONTHLY // valor por usuário ativo — usado em planos SELF_SERVICE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum CompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum ServiceStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

enum PersonType {
  CANDIDATO
  COLABORADOR
}

enum EntityType {
  COMPANY
  PERSON
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  DOCUMENT
  HANDOFF
  MENTION
  CREATED
  PRIORITY_CHANGE
  DUE_DATE_CHANGE
  DESCRIPTION_CHANGE
  ASSIGNEE_CHANGE
  TAG_CHANGE
  CHECKLIST_CHANGE
  SUBTASK_CHANGE
  COMPLETED
  REOPENED
  TIME_LOGGED
}

// Situação da transferência em cada setor de destino:
// NEW = "Nova", IN_PROGRESS = "Resolvendo", DONE = "Finalizada".
enum HandoffSectorStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum HandoffPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AiProvider {
  ANTHROPIC
  OPENAI
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
  TEXTAREA
}

enum PipelineEntityType {
  COMPANY
  PERSON
}

// Tipo visual do estágio (bolinha na visão de lista/subtarefas) — NOT_STARTED
// vazia, IN_PROGRESS preenchida pela metade, PENDING pontilhada, DONE cheia
// com check. isTerminal continua no schema (muita leitura já existente) e
// passa a ser derivado: DONE => isTerminal true, qualquer outro => false.
enum StageType {
  NOT_STARTED
  IN_PROGRESS
  PENDING
  DONE
}

// ─── RH/DP + Recrutamento ──────────────────────────────────────────────────────

enum PersonEmploymentStatus {
  ATIVO
  DESLIGADO
  AFASTADO
  EM_FERIAS
  ADMISSAO_EM_ANDAMENTO
}

enum VagaStatus {
  ABERTA
  EM_ANDAMENTO
  ENCERRADA
  CANCELADA
}

enum VagaPrioridade {
  BAIXA
  MEDIA
  ALTA
}

enum ProcessoSeletivoStatus {
  EM_ANDAMENTO
  APROVADO
  REPROVADO
  DESISTENTE
  CONTRATADO
  ENCERRADO
}

// Etapa no funil de recrutamento — dimensão ORTOGONAL ao status (que é o
// resultado). O status diz se a candidatura está ativa/reprovada/contratada; o
// stage diz até onde ela avançou no processo. Preservado mesmo em reprovados/
// desistentes (é o que permite medir "quantos alcançaram cada etapa" sem
// tabela de histórico). Ordem: TRIAGEM < ENTREVISTA < TESTE < PROPOSTA < CONTRATADO.
enum RecruitmentStage {
  TRIAGEM
  ENTREVISTA
  TESTE
  PROPOSTA
  CONTRATADO
}

enum InterviewRecommendation {
  AVANCAR
  TALVEZ
  REPROVAR
}

enum ExameAdmissionalStatus {
  SOLICITADO
  AGENDADO
  REALIZADO
  ASO_PENDENTE
  ASO_APTO
  ASO_INAPTO
  ASO_APTO_COM_RESTRICAO
}

enum DocumentEntityType {
  PERSON
  COMPANY
  VAGA
  PIPELINE_ITEM
}

enum DocumentCategory {
  ADMISSAO
  ASO
  CURRICULO
  ATESTADO
  CERTIFICADO
  RECIBO
  CONTRATO
  OUTRO
}

enum ClientDocumentStatus {
  DRAFT
  PUBLISHED
}

enum ClientDocumentViewAction {
  VIEWED
  DOWNLOADED
  SIGNED
}

enum AdmissaoLinkStatus {
  PENDENTE // link gerado, aguardando preenchimento pelo colaborador
  PREENCHIDO // colaborador submeteu dados e documentos
  CONCLUIDO // DP conferiu e concluiu a admissão (Person → ATIVO)
}

enum DependenteRelationship {
  CONJUGE
  COMPANHEIRO
  FILHO
  ENTEADO
  PAIS
  OUTRO
}

enum SensitiveFieldGroup {
  DADOS_BANCARIOS
  DADOS_MEDICOS
  SALARIO
  DOCUMENTOS_PESSOAIS
}

enum VacationStatus {
  PLANEJADA
  SOLICITADA
  EM_ANALISE
  APROVADA
  PROGRAMADA
  EM_GOZO
  CONCLUIDA
  CANCELADA
}

enum AbsenceType {
  FALTA
  ATESTADO_PARCIAL
  ATESTADO_INTEGRAL
  LICENCA
  AFASTAMENTO
  RETORNO
}

enum AbsenceStatus {
  LANCADO
  EM_ANALISE
  APROVADO
  REPROVADO
  AFASTADO
  RETORNO_PREVISTO
  CONCLUIDO
}

enum TerminationType {
  VOLUNTARIO
  INVOLUNTARIO
  TERMINO_CONTRATO
  EXPERIENCIA
  JUSTA_CAUSA
  SEM_JUSTA_CAUSA
}

enum TerminationStatus {
  SOLICITADO
  EM_CALCULO
  DOCUMENTACAO_PENDENTE
  ASSINATURA_PENDENTE
  FINALIZADO
  CANCELADO
}

enum PayrollStatus {
  PENDENTE
  EM_CONFERENCIA
  CONFERIDO
  ENVIADO
  PROCESSADO
  CANCELADO
}

enum DayType {
  UTIL
  FOLGA
  DOMINGO
  FERIADO
  NOTURNO
}

enum OvertimeStatus {
  LANCADO
  PENDENTE_APROVACAO
  APROVADO
  REPROVADO
  ENVIADO_FOLHA
}

enum BenefitType {
  VALE_REFEICAO
  VALE_ALIMENTACAO
  VALE_TRANSPORTE
  AUXILIO_COMBUSTIVEL
  PLANO_SAUDE
  PLANO_ODONTOLOGICO
  CONVENIO_FARMACIA
  CONVENIO_SESC
  TOTALPASS
  AUXILIO_EDUCACAO
  ASSIDUIDADE
  OUTRO
}

enum BenefitStatus {
  ATIVO
  INATIVO
  SUSPENSO
  PENDENTE
  CANCELADO
}

enum ScheduleStatus {
  PLANEJADA
  CONFIRMADA
  ALTERADA
  CANCELADA
