// ─── Tenancy + Auth ──────────────────────────────────────────────────────────

model Tenant {
  id             String         @id @default(uuid())
  name           String         @db.VarChar(120)
  cnpj           String?        @unique @db.VarChar(18)
  slug           String         @unique @db.VarChar(60)
  plan           String         @default("starter") @db.VarChar(40)
  managementMode ManagementMode @default(MANAGED)
  logoUrl        String?        @db.VarChar(255)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscription         Subscription?
  users                User[]
  companies            Company[]
  people               Person[]
  pipelines            Pipeline[]
  pipelineItems        PipelineItem[]
  activities           Activity[]
  handoffs             Handoff[]
  handoffSectors       HandoffSector[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  admissaoLinks        AdmissaoLink[]
  dependentes          Dependente[]
  customFields         CustomField[]
  customValues         CustomValue[]
  sectors              Sector[]
  tenantModules        TenantModule[]
  tags                 Tag[]
  branches             Branch[]
  accessGrants         UserTenantAccess[]
  departments          Department[]
  cargos               Cargo[]
  vagas                Vaga[]
  candidaturas         Candidatura[]
  exames               ExameAdmissional[]
  interviewScorecards  InterviewScorecard[]
  documents            Document[]
  fieldPermissions     FieldPermission[]
  salaryChanges        SalaryChange[]
  vacations            Vacation[]
  absences             Absence[]
  terminations         Termination[]
  payrollCompetencies  PayrollCompetency[]
  payrollEntries       PayrollEntry[]
  overtimeEntries      OvertimeEntry[]
  benefitCatalogs      BenefitCatalog[]
  benefitAssignments   BenefitAssignment[]
  workShifts           WorkShift[]
  holidays             Holiday[]
  scheduleEntries      ScheduleEntry[]
  trainings            Training[]
  trainingClasses      TrainingClass[]
  trainingParticipants TrainingParticipant[]
  competencies         Competency[]
  evaluationCycles     EvaluationCycle[]
  evaluations          Evaluation[]
  evaluationScores     EvaluationScore[]
  handoffViews         HandoffView[]
  checklistItems       ChecklistItem[]
  timeEntries          TimeEntry[]
  spaces               Space[]
  folders              Folder[]
  pipelineItemLinks    PipelineItemLink[]
  canvasPages          CanvasPage[]
  auditLogs            AuditLog[]
  oauthAccounts        OAuthAccount[]
  meetings             Meeting[]
  clientDocuments      ClientDocument[]
  smtpConfig           TenantSmtpConfig?
  aiConfig             TenantAiConfig?
  alertDispatches      AlertDispatch[]
  recurringObligations RecurringObligation[]
  chatwootConnections  ChatwootConnection[]
  bpoCredentials       BpoCredential[]
  bpoCredentialViews   BpoCredentialView[]
  chatwootAgentLinks   ChatwootAgentLink[]

  @@map("tenants")
}

// Acesso de um SUPER_ADMIN a um tenant além do seu próprio (User.tenantId) —
// permite que o suporte da 41 Tech alterne entre workspaces de clientes sem
// precisar de uma conta separada por cliente. Só tem efeito para SUPER_ADMIN;
// os demais papéis continuam presos ao tenant do próprio usuário.
model UserTenantAccess {
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@map("user_tenant_access")
}

// Filial de um tenant — puramente organizacional (etiqueta/contexto), não isola
// dados: uma Empresa pode ser marcada com a filial que a atende, mas continua
// visível/editável normalmente por qualquer usuário do tenant com acesso a ela.
model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String   @db.VarChar(120)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  companies Company[]

  @@index([tenantId])
  @@map("branches")
}

// Setor/cargo cadastrável — referenciado por código (string livre, sem FK) em
// UserSector, CompanyService, Pipeline, Handoff. O código não muda após criado
// pois já pode estar espalhado nesses registros; label/cor/ordem são editáveis.
model Sector {
  id        String   @id @default(uuid())
  tenantId  String
  code      String   @db.VarChar(40)
  label     String   @db.VarChar(80)
  color     String   @default("#586577") @db.VarChar(7)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sectors")
}

// Estado de ativação de um módulo (Recrutamento, RH/DP...) por tenant. O catálogo
// de módulos disponíveis vive em código (src/lib/modules.ts) — só nasce um módulo
// novo quando a tela dele existe de verdade. Esta tabela só guarda o "ligado" ou
// "desligado" de cada módulo do catálogo para cada cliente (preparação para
// comercialização: cliente A pode ter Recrutamento, cliente B pode não ter).
// Ausência de linha = usa o `defaultEnabled` do catálogo.
model TenantModule {
  id         String   @id @default(uuid())
  tenantId   String
  moduleCode String   @db.VarChar(60)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleCode])
  @@index([tenantId])
  @@map("tenant_modules")
}

// Catálogo de planos comercializáveis (vive em código+banco, editável só por
// SUPER_ADMIN) — cada plano já fixa o modo de gestão (frente 1 vs frente 2 do
// levantamento comercial) e como é cobrado.
model SubscriptionPlan {
  id             String         @id @default(uuid())
  name           String         @db.VarChar(80)
  managementMode ManagementMode
  billingType    BillingType
  basePrice      Decimal        @default(0) @db.Decimal(10, 2) // usado quando billingType = FLAT_MONTHLY
  pricePerUser   Decimal?       @db.Decimal(10, 2) // usado quando billingType = PER_USER_MONTHLY
  setupFee       Decimal        @default(0) @db.Decimal(10, 2)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

// Assinatura ativa de um tenant — 1:1. Controle manual (sem gateway de
// pagamento integrado ainda): a 41 Tech marca status/pagamento da implantação
// à mão em /admin/assinaturas.
model Subscription {
  id               String             @id @default(uuid())
  tenantId         String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIAL)
  seatLimit        Int? // limite de usuários — só relevante em planos PER_USER_MONTHLY
  startedAt        DateTime           @default(now())
  currentPeriodEnd DateTime?
  setupFeeAmount   Decimal?           @db.Decimal(10, 2)
  setupFeePaidAt   DateTime?
  notes            String?            @db.Text
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscriptions")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  name         String   @db.VarChar(120)
  email        String   @db.VarChar(120)
  passwordHash String   @db.VarChar(255)
  photoUrl     String?  @db.VarChar(255)
  role         UserRole @default(SECTOR_USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant                 Tenant                 @relation(fields: [tenantId], references: [id])
  sectors                UserSector[]
  assignedItems          PipelineItemAssignee[]
  watchedItems           PipelineItemWatcher[]
  timeEntries            TimeEntry[]
  canvasPages            CanvasPage[]
  activities             Activity[]
  handoffs               Handoff[]              @relation("HandoffRequester")
  handoffSectorsAssigned HandoffSector[]        @relation("HandoffSectorAssignee")
  handoffViews           HandoffView[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  tenantAccess           UserTenantAccess[]
  uploadedDocuments      Document[]
  evaluationsGiven       Evaluation[]
  auditLogs              AuditLog[]
  responsibleFor         CompanyService[]       @relation("CompanyServiceResponsible")
  oauthAccounts          OAuthAccount[]
  meetingsCreated        Meeting[]              @relation("MeetingCreatedBy")
  meetingAttendances     MeetingAttendee[]
  clientDocumentsCreated ClientDocument[]
  recurringObligations   RecurringObligation[]
  admissaoLinksCreated   AdmissaoLink[]
  interviewScorecards    InterviewScorecard[]
  linkedPerson           Person?
  bpoCredentialsCreated  BpoCredential[]
  bpoCredentialViews     BpoCredentialView[]
  chatwootAgentLinks     ChatwootAgentLink[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// Quais setores um usuário pode acessar
model UserSector {
  userId     String
  sectorCode String @db.VarChar(40)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sectorCode])
  @@map("user_sectors")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

// Token de redefinição de senha por e-mail — mesmo padrão do RefreshToken
// (hash armazenado, nunca o token cru; de uso único via usedAt).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Entidades Centrais ───────────────────────────────────────────────────────

model Company {
  id                    String        @id @default(uuid())
  tenantId              String
  // Identificação
  name                  String        @db.VarChar(180) // Razão Social
  tradeName             String?       @db.VarChar(180) // Nome Fantasia
  cnpj                  String?       @db.VarChar(18)
  taxRegime             String?       @db.VarChar(100) // Regime Tributário — algumas opções (ex: "Simples Nacional - Comércio ou Serviço - Com Pró-labore - Com Funcionários") passam de 60 chars, causavam P2000 ao salvar
  externalId            String?       @db.VarChar(60) // ID manual do sistema de domínio (ex: Acessorias) — sem sincronização
  foundationDate        DateTime? // Data de abertura da empresa
  cnaePrincipal         String?       @db.VarChar(20) // Código CNAE principal, ex: 6920-6/01
  cnaeSecundarios       String?       @db.Text // Lista de códigos CNAE secundários, separados por vírgula
  // Endereço
  zipCode               String?       @db.VarChar(10)
  addressStreet         String?       @db.VarChar(180)
  addressNumber         String?       @db.VarChar(20)
  addressComplement     String?       @db.VarChar(80)
  neighborhood          String?       @db.VarChar(80)
  city                  String?       @db.VarChar(80)
  stateCode             String?       @db.VarChar(2)
  // Inscrições fiscais
  stateRegistration     String?       @db.VarChar(40)
  municipalRegistration String?       @db.VarChar(40)
  nire                  String?       @db.VarChar(20)
  // Contato
  email                 String?       @db.VarChar(120)
  phone                 String?       @db.VarChar(30)
  website               String?       @db.VarChar(255)
  logoUrl               String?       @db.VarChar(255)
  // CRM
  status                CompanyStatus @default(PROSPECT)
  source                String?       @db.VarChar(80)
  responsibleUserId     String?
  branchId              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  services             CompanyService[]
  people               Person[]
  departments          Department[]
  cargos               Cargo[]
  vagas                Vaga[]
  payrollCompetencies  PayrollCompetency[]
  benefitCatalogs      BenefitCatalog[]
  workShifts           WorkShift[]
  meetings             Meeting[]
  clientDocuments      ClientDocument[]
  recurringObligations RecurringObligation[]
  chatwootContactLinks ChatwootContactLink[]
  bpoCredentials       BpoCredential[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("companies")
}

// Qual serviço (setor) uma empresa contratou. responsibleUserId é o
// "responsável" por setor/serviço (nomenclatura "tag" no Acessorias, a
// referência do usuário) — ex: Contábil -> João.
model CompanyService {
  id                String        @id @default(uuid())
  companyId         String
  tenantId          String
  sectorCode        String        @db.VarChar(40)
  responsibleUserId String?
  startDate         DateTime?
  endDate           DateTime?
  status            ServiceStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responsible User?   @relation("CompanyServiceResponsible", fields: [responsibleUserId], references: [id])

  @@unique([companyId, sectorCode])
  @@index([tenantId, sectorCode])
  @@map("company_services")
}

model Person {
  id               String     @id @default(uuid())
  tenantId         String
  name             String     @db.VarChar(180)
  cpf              String?    @db.VarChar(14)
  email            String?    @db.VarChar(120)
  phone            String?    @db.VarChar(30)
  photoUrl         String?    @db.VarChar(255)
  birthDate        DateTime?
  type             PersonType @default(CANDIDATO)
  active           Boolean    @default(true)
  currentCompanyId String?
  // true = funcionário interno (RH da própria 41), false = colaborador/candidato
  // de empresa cliente. Frente separada da conta de acesso ao sistema (User) —
  // ver linkedUserId abaixo.
  isInternal       Boolean    @default(false)
  // FK opcional pro User de acesso ao sistema (login/permissões) — só faz
  // sentido quando isInternal=true. Gestão de dados gerais (nome, endereço,
  // documentos) fica aqui em Person; gestão de acesso (senha, e-mail,
  // permissões) continua exclusivamente em /admin/usuarios (User).
  linkedUserId     String?    @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // ─── Dados trabalhistas (Núcleo de Colaboradores) ───────────────────────────
  rg                String?                @db.VarChar(20)
  pis               String?                @db.VarChar(20)
  ctps              String?                @db.VarChar(20)
  ctpsSerie         String?                @db.VarChar(10)
  admissionDate     DateTime?
  dismissalDate     DateTime?
  employmentStatus  PersonEmploymentStatus @default(ADMISSAO_EM_ANDAMENTO)
  cargoId           String?
  departmentId      String?
  monthlyWorkHours  Decimal?               @db.Decimal(6, 2)
  weeklyWorkHours   Decimal?               @db.Decimal(5, 2)
  workShift         String?                @db.VarChar(60)
  currentSalary     Decimal?               @db.Decimal(12, 2)
  bankName          String?                @db.VarChar(80)
  bankAgency        String?                @db.VarChar(20)
  bankAccount       String?                @db.VarChar(30)
  bankAccountType   String?                @db.VarChar(20)
  zipCode           String?                @db.VarChar(10)
  addressStreet     String?                @db.VarChar(180)
  addressNumber     String?                @db.VarChar(20)
  addressComplement String?                @db.VarChar(80)
  neighborhood      String?                @db.VarChar(80)
  city              String?                @db.VarChar(80)
  stateCode         String?                @db.VarChar(2)
  education         String?                @db.VarChar(80)
  notes             String?                @db.Text // Observações livres sobre a pessoa

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  currentCompany Company?    @relation(fields: [currentCompanyId], references: [id])
  cargo          Cargo?      @relation(fields: [cargoId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  linkedUser     User?       @relation(fields: [linkedUserId], references: [id])

  candidaturas         Candidatura[]
  exames               ExameAdmissional[]
  salaryChanges        SalaryChange[]
  vacations            Vacation[]
  absences             Absence[]
  terminations         Termination[]
  payrollEntries       PayrollEntry[]
  overtimeEntries      OvertimeEntry[]
  benefitAssignments   BenefitAssignment[]
  scheduleEntries      ScheduleEntry[]
  trainingParticipants TrainingParticipant[]
  evaluations          Evaluation[]
  chatwootContactLinks ChatwootContactLink[]
  admissaoLinks        AdmissaoLink[]
  dependentes          Dependente[]
  tags                 PersonTag[]

  @@unique([tenantId, cpf])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isInternal])
  @@map("people")
}

// ─── Motor genérico de Pipeline ───────────────────────────────────────────────

// Espaço — agrupamento organizacional DENTRO de um setor (não é o setor em
// si). Um setor pode ter vários espaços (ex.: setor "bpo" com espaços "BLD",
// "BPO", cada um agrupando um conjunto diferente de clientes/pastas/listas).
// Toda Lista (Pipeline) pertence a um espaço — nunca solta.
model Space {
  id         String   @id @default(uuid())
  tenantId   String
  sectorCode String   @db.VarChar(40)
  name       String   @db.VarChar(80)
  color      String   @default("#586577") @db.VarChar(7)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  folders   Folder[]
  pipelines Pipeline[]

  @@unique([tenantId, sectorCode, name])
  @@index([tenantId, sectorCode])
  @@map("spaces")
}

// Pasta — opcional, sempre dentro de um Espaço. Agrupa Listas relacionadas
// (ex.: espaço "BPO" com pastas "Financeiro", "Coordenação").
model Folder {
  id        String   @id @default(uuid())
  tenantId  String
  spaceId   String
  name      String   @db.VarChar(80)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  pipelines Pipeline[]

  @@index([tenantId, spaceId])
  @@map("folders")
}

model Pipeline {
  id          String             @id @default(uuid())
  tenantId    String
  sectorCode  String             @db.VarChar(40)
  spaceId     String
  folderId    String?
  name        String             @db.VarChar(120)
  description String?            @db.Text
  color       String?            @db.VarChar(7)
  startDate   DateTime?
  endDate     DateTime?
  entityType  PipelineEntityType
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  space                Space                 @relation(fields: [spaceId], references: [id])
  folder               Folder?               @relation(fields: [folderId], references: [id])
  stages               PipelineStage[]
  items                PipelineItem[]
  recurringObligations RecurringObligation[]

  @@index([tenantId, sectorCode])
  @@index([spaceId])
  @@index([folderId])
  @@map("pipelines")
}

model PipelineStage {
  id         String    @id @default(uuid())
  pipelineId String
  name       String    @db.VarChar(80)
  order      Int
  color      String?   @db.VarChar(7) // hex, ex: #1A5FA8
  isTerminal Boolean   @default(false)
  type       StageType @default(NOT_STARTED)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  pipeline Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  items    PipelineItem[]

  @@unique([pipelineId, order])
  @@map("pipeline_stages")
}

model PipelineItem {
  id                   String              @id @default(uuid())
  tenantId             String
  pipelineId           String
  stageId              String
  // Opcional — nem toda tarefa está associada a uma empresa/pessoa específica
  // (ex.: tarefa interna do setor). Quando nulo, `title` é obrigatório.
  entityType           PipelineEntityType?
  entityId             String? // Company.id ou Person.id (referência por string, sem FK Prisma — relação polimórfica)
  // Título próprio, opcional quando há entidade — item de topo com entidade
  // normalmente usa o nome da entidade (entityName resolvido em runtime) como
  // título; subtarefa e tarefa sem entidade sempre têm título próprio.
  title                String?             @db.VarChar(200)
  // Subtarefa: mesma tabela (PipelineItem) com parentItemId apontando pro item
  // "mãe" — reaproveita status/prioridade/prazo/responsável/tags/atividades/
  // anexos que já existem pra qualquer PipelineItem, sem duplicar modelo. Só
  // 1 nível (subtarefa de subtarefa não é permitido, controlado na action).
  parentItemId         String?
  // Ordem manual dentro do (pipelineId, stageId, parentItemId) — drag-and-drop
  // de reordenar na tabela de tarefas (mesmo mecanismo do ChecklistItem.order).
  order                Int                 @default(0)
  priority             Int                 @default(0)
  startDate            DateTime?
  dueDate              DateTime?
  description          String?             @db.Text
  // Estimativa manual de esforço, em minutos — opcional (item nunca obriga
  // controle de tempo). Tempo efetivamente gasto vem da soma de TimeEntry.
  estimateMinutes      Int?
  // Cronômetro ao vivo — só 1 usuário por vez rastreando tempo num item;
  // "Parar" converte em TimeEntry e limpa os dois campos.
  activeTimerUserId    String?
  activeTimerStartedAt DateTime?
  // Recorrência — só marca a intenção/frequência no item (mostra o ícone na
  // UI); a geração automática de novas ocorrências fica pra uma extensão
  // futura, não duplicar o motor de RecurringObligation aqui.
  recurring            Boolean             @default(false)
  recurrenceFrequency  RecurringFrequency?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  pipeline    Pipeline               @relation(fields: [pipelineId], references: [id])
  stage       PipelineStage          @relation(fields: [stageId], references: [id])
  parent      PipelineItem?          @relation("SubTasks", fields: [parentItemId], references: [id], onDelete: Cascade)
  subtasks    PipelineItem[]         @relation("SubTasks")
  linksFrom   PipelineItemLink[]     @relation("LinkSource")
  linksTo     PipelineItemLink[]     @relation("LinkTarget")
  activities  Activity[]
  assignees   PipelineItemAssignee[]
  watchers    PipelineItemWatcher[]
  tags        PipelineItemTag[]
  checklist   ChecklistItem[]
  timeEntries TimeEntry[]
  canvasPages CanvasPage[]
  candidatura Candidatura?
  meetings    Meeting[]

  @@index([tenantId, pipelineId])
  @@index([tenantId, entityType, entityId])
  @@index([parentItemId])
  @@index([pipelineId, stageId, parentItemId, order])
  @@map("pipeline_items")
}

// Documento "canvas" — página em branco (não é upload de arquivo), sempre
// vinculada a uma tarefa. Agregada na UI do Espaço/Pasta dona da Lista dessa
// tarefa, pra ficar visível pra quem não abriu a tarefa específica.
model CanvasPage {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineItemId String
  title          String   @db.VarChar(160)
  content        String?  @db.Text // HTML do RichTextEditor, sanitizado no servidor
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([tenantId, pipelineItemId])
  @@map("canvas_pages")
}

// Vínculo/dependência entre duas tarefas (independente de subtarefa) — só
// registra a relação, sem bloquear nada automaticamente (não há motor de
// dependência bloqueante hoje).
model PipelineItemLink {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineItemId String
  linkedItemId   String
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  pipelineItem PipelineItem @relation("LinkSource", fields: [pipelineItemId], references: [id], onDelete: Cascade)
  linkedItem   PipelineItem @relation("LinkTarget", fields: [linkedItemId], references: [id], onDelete: Cascade)

  @@unique([pipelineItemId, linkedItemId])
  @@map("pipeline_item_links")
}

// Checklist simples (sem virar subtarefa) — item de topo e subtarefa podem
// ambos ter o próprio checklist.
model ChecklistItem {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineItemId String
  text           String   @db.VarChar(280)
  done           Boolean  @default(false)
  order          Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, pipelineItemId])
  @@map("checklist_items")
}

// Apontamento manual de tempo gasto numa tarefa/subtarefa — por usuário, sem
// cronômetro ao vivo (lançamento simples: quantos minutos, quando, nota opcional).
model TimeEntry {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineItemId String
  userId         String
  minutes        Int
  note           String?  @db.VarChar(280)
  loggedOn       DateTime // data-calendário do trabalho (pode ser retroativo)
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([tenantId, pipelineItemId])
  @@map("time_entries")
}

// Responsáveis internos de um item — N:N (substitui o antigo assignedUserId singular)
model PipelineItemAssignee {
  pipelineItemId String
  userId         String
  // Prioridade específica desse responsável nessa tarefa — pode divergir da
  // prioridade "geral" do item (PipelineItem.priority, usada quando não há
  // responsável ou como valor de referência).
  priority       Int      @default(0)
  createdAt      DateTime @default(now())

  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pipelineItemId, userId])
  @@map("pipeline_item_assignees")
}

// Participantes/observadores de um item — acompanham a tarefa sem serem
// responsáveis por executá-la (distinção pedida no espelho do ClickUp).
// Recebem notificação de novos comentários, mas não aparecem como "assignee".
model PipelineItemWatcher {
  pipelineItemId String
  userId         String
  createdAt      DateTime @default(now())

  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pipelineItemId, userId])
  @@map("pipeline_item_watchers")
}

// Catálogo de tags por setor — reaproveitável entre todos os kanbans do mesmo setor
model Tag {
  id         String   @id @default(uuid())
  tenantId   String
  sectorCode String   @db.VarChar(40)
  name       String   @db.VarChar(60)
  color      String   @default("#586577") @db.VarChar(7)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  items  PipelineItemTag[]
  people PersonTag[]

  @@unique([tenantId, sectorCode, name])
  @@index([tenantId, sectorCode])
  @@map("tags")
}

model PipelineItemTag {
  pipelineItemId String
  tagId          String

  pipelineItem PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pipelineItemId, tagId])
  @@map("pipeline_item_tags")
}

// Tag/skill de um candidato (banco de talentos) — mesmo catálogo de Tag já
// usado no Kanban (setor "recrutamento"), só um join novo. Não regride quando
// a candidatura é reprovada/desistente: é o que torna o candidato pesquisável
// pra vagas futuras mesmo depois de um processo específico não dar certo.
model PersonTag {
  personId String
  tagId    String

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([personId, tagId])
  @@map("person_tags")
}

// ─── Atividades (timeline) ────────────────────────────────────────────────────

model Activity {
  id               String       @id @default(uuid())
  tenantId         String
  pipelineItemId   String
  userId           String
  type             ActivityType
  content          String?      @db.Text
  metadata         Json? // dados extras (ex: stageFrom, stageTo no STATUS_CHANGE)
  // Resposta a um comentário específico (só faz sentido em NOTE) — self-relation;
  // um NOTE sem parentActivityId é um comentário de topo, com parentActivityId é
  // uma resposta. Eventos automáticos nunca têm parentActivityId.
  parentActivityId String?
  editedAt         DateTime? // preenchido quando o autor edita a própria nota
  createdAt        DateTime     @default(now())

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  pipelineItem   PipelineItem @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  parentActivity Activity?    @relation("ActivityReplies", fields: [parentActivityId], references: [id], onDelete: Cascade)
  replies        Activity[]   @relation("ActivityReplies")

  @@index([tenantId, pipelineItemId])
  @@index([parentActivityId])
  @@map("activities")
}

// ─── Configuração flexível (preenchida pós-discovery) ─────────────────────────

model CustomField {
  id         String          @id @default(uuid())
  tenantId   String
  sectorCode String          @db.VarChar(40)
  entityType EntityType
  key        String          @db.VarChar(80)
  label      String          @db.VarChar(120)
  fieldType  CustomFieldType
  options    Json? // para SELECT: array de strings
  required   Boolean         @default(false)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  values CustomValue[]

  @@unique([tenantId, sectorCode, entityType, key])
  @@index([tenantId, sectorCode])
  @@map("custom_fields")
}

model CustomValue {
  id            String   @id @default(uuid())
  tenantId      String
  customFieldId String
  entityId      String // Company.id ou Person.id
  value         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([tenantId, entityId])
  @@map("custom_values")
}

// ─── RH/DP + Recrutamento ──────────────────────────────────────────────────────

// Departamento/Seção interna da empresa-cliente — diferente do Sector (setor de
// atendimento da 41 Tech: Fiscal, DP, Recrutamento etc.).
model Department {
  id        String   @id @default(uuid())
  tenantId  String
  companyId String
  name      String   @db.VarChar(120)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  people  Person[]

  @@unique([companyId, name])
  @@index([tenantId])
  @@map("departments")
}

// Catálogo de cargos por empresa-cliente (não compartilhado entre empresas do tenant).
model Cargo {
  id                     String   @id @default(uuid())
  tenantId               String
  companyId              String
  name                   String   @db.VarChar(120)
  area                   String?  @db.VarChar(80)
  description            String?  @db.Text
  technicalRequirements  String?  @db.Text
  behavioralRequirements String?  @db.Text
  salaryRangeMin         Decimal? @db.Decimal(12, 2)
  salaryRangeMid         Decimal? @db.Decimal(12, 2)
  salaryRangeMax         Decimal? @db.Decimal(12, 2)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vagas         Vaga[]
  people        Person[]
  salaryChanges SalaryChange[]

  @@unique([companyId, name])
  @@index([tenantId, companyId])
  @@map("cargos")
}

model Vaga {
  id                String         @id @default(uuid())
  tenantId          String
  companyId         String
  cargoId           String?
  sectorCode        String         @db.VarChar(40)
  title             String         @db.VarChar(180)
  quantity          Int            @default(1)
  responsibleUserId String?
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  status            VagaStatus     @default(ABERTA)
  priority          VagaPrioridade @default(MEDIA)
  notes             String?        @db.Text
  // Portal público (/carreiras/[slug]) — isPublic expõe a vaga; a descrição
  // pública é separada de notes (que é anotação interna do recrutador).
  isPublic          Boolean        @default(false)
  publicDescription String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  cargo   Cargo?  @relation(fields: [cargoId], references: [id])

  candidaturas Candidatura[]

  @@index([tenantId, sectorCode, status])
  @@map("vagas")
}

// Liga um Person (candidato) a uma Vaga. O vínculo com PipelineItem é opcional —
// nem toda candidatura precisa de um Kanban por trás, mas quando existe reaproveita
// o motor de Pipeline/Tags/Timeline já pronto para a visualização em colunas.
model Candidatura {
  id               String                 @id @default(uuid())
  tenantId         String
  vagaId           String
  personId         String
  pipelineItemId   String?                @unique
  origin           String?                @db.VarChar(80)
  resumeUrl        String?                @db.VarChar(255)
  status           ProcessoSeletivoStatus @default(EM_ANDAMENTO)
  stage            RecruitmentStage       @default(TRIAGEM)
  rejectionReason  String?                @db.Text
  withdrawalReason String?                @db.Text
  hiredAt          DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  vaga         Vaga                 @relation(fields: [vagaId], references: [id])
  person       Person               @relation(fields: [personId], references: [id])
  pipelineItem PipelineItem?        @relation(fields: [pipelineItemId], references: [id])
  exames       ExameAdmissional[]
  scorecards   InterviewScorecard[]
  meetings     Meeting[]

  @@unique([vagaId, personId])
  @@index([tenantId, vagaId])
  @@map("candidaturas")
}

model ExameAdmissional {
  id            String                 @id @default(uuid())
  tenantId      String
  personId      String
  candidaturaId String?
  clinicName    String?                @db.VarChar(120)
  requestedAt   DateTime               @default(now())
  scheduledAt   DateTime?
  performedAt   DateTime?
  asoDueDate    DateTime?
  status        ExameAdmissionalStatus @default(SOLICITADO)
  notes         String?                @db.Text
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  person      Person       @relation(fields: [personId], references: [id])
  candidatura Candidatura? @relation(fields: [candidaturaId], references: [id])

  @@index([tenantId, personId])
  @@map("exames_admissionais")
}

// Mecanismo genérico de anexo, reaproveitável por qualquer entidade/módulo.
model Document {
  id           String             @id @default(uuid())
  tenantId     String
  entityType   DocumentEntityType
  entityId     String
  category     DocumentCategory
  fileName     String             @db.VarChar(180)
  fileUrl      String             @db.VarChar(255)
  mimeType     String             @db.VarChar(100)
  fileSize     Int
  sensitive    Boolean            @default(false)
  // Vencimento opcional (ASO, CNH, certificado NR, contrato, procuração...) —
  // meia-noite UTC como toda data-calendário. Alimenta o alerta DOC_EXPIRING
  // do motor de alertas (src/lib/alerts.ts).
  expiresAt    DateTime?
  uploadedById String
  createdAt    DateTime           @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, expiresAt])
  @@map("documents")
}

// Documento formal enviado a um cliente (Company) por e-mail — inspirado no
// Acessórias. Diferente do Document genérico acima: é público (visualizável sem
// login via ClientDocumentRecipient.token) e serve de prova de recebimento.
// Trava de integridade: uma vez que exista recipient.sentAt, bodyHtml/arquivo
// não devem mais ser editados (o link já enviado precisa mostrar sempre o
// mesmo conteúdo que foi de fato visualizado).
model ClientDocument {
  id                String               @id @default(uuid())
  tenantId          String
  companyId         String
  title             String               @db.VarChar(180)
  bodyHtml          String               @db.Text
  fileName          String?              @db.VarChar(180)
  fileUrl           String?              @db.VarChar(255)
  mimeType          String?              @db.VarChar(100)
  fileSize          Int?
  status            ClientDocumentStatus @default(DRAFT)
  // Assinatura eletrônica (extensão da admissão digital): quando true, o
  // destinatário precisa assinar na página pública (/d/{token}) — nome + aceite
  // registrados em ClientDocumentRecipient. Não é assinatura digital ICP-Brasil,
  // é aceite eletrônico com trilha (nome/IP/data) na mesma linha da prova de
  // recebimento que este módulo já registra.
  requiresSignature Boolean              @default(false)
  publishedAt       DateTime?
  createdById       String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant     Tenant                    @relation(fields: [tenantId], references: [id])
  company    Company                   @relation(fields: [companyId], references: [id])
  createdBy  User                      @relation(fields: [createdById], references: [id])
  recipients ClientDocumentRecipient[]

  @@index([tenantId, companyId])
  @@map("client_documents")
}

// Um destinatário de um envio — token único vira o link público (/d/{token}).
// sentAt marca o envio; first/lastViewedAt são um resumo denormalizado (o log
// completo de cada abertura/download vive em ClientDocumentView).
model ClientDocumentRecipient {
  id               String    @id @default(uuid())
  clientDocumentId String
  email            String    @db.VarChar(180)
  token            String    @unique @db.VarChar(64)
  sentAt           DateTime?
  firstViewedAt    DateTime?
  lastViewedAt     DateTime?
  // Aceite eletrônico (só usado quando o ClientDocument.requiresSignature)
  signedAt         DateTime?
  signerName       String?   @db.VarChar(180)
  signerIp         String?   @db.VarChar(64)
  createdAt        DateTime  @default(now())

  clientDocument ClientDocument       @relation(fields: [clientDocumentId], references: [id])
  views          ClientDocumentView[]

  @@index([clientDocumentId])
  @@map("client_document_recipients")
}

// Log de prova: uma linha por abertura de link ou download de anexo, nunca
// deduplicado — é a evidência que sustenta "o cliente visualizou em tal
// data/hora, deste IP".
model ClientDocumentView {
  id          String                   @id @default(uuid())
  recipientId String
  action      ClientDocumentViewAction @default(VIEWED)
  ipAddress   String                   @db.VarChar(64)
  userAgent   String?                  @db.VarChar(255)
  viewedAt    DateTime                 @default(now())

  recipient ClientDocumentRecipient @relation(fields: [recipientId], references: [id])

  @@index([recipientId])
  @@map("client_document_views")
}

// Config de SMTP por tenant (Connect 41 é comercializado para vários
// escritórios — não pode depender de uma conta SMTP fixa do 41 Tech).
// passwordEnc nunca fica em texto puro — ver src/lib/crypto.ts (AES-256-GCM).
model TenantSmtpConfig {
  id          String   @id @default(uuid())
  tenantId    String   @unique
  host        String   @db.VarChar(180)
  port        Int
  secure      Boolean  @default(true)
  username    String   @db.VarChar(180)
  passwordEnc String   @db.Text
  fromName    String   @db.VarChar(120)
  fromEmail   String   @db.VarChar(180)
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_smtp_configs")
}

// Config de provedor de IA por tenant (Anthropic ou OpenAI) — mesma lógica do
// TenantSmtpConfig: cada escritório usa a própria chave/conta, configurável em
// Integrações → Inteligência Artificial. apiKeyEnc nunca fica em texto puro
// (AES-256-GCM, ver src/lib/crypto.ts). Ausência de linha = usa o fallback
// global via env (ANTHROPIC_API_KEY/OPENAI_API_KEY), se existir.
model TenantAiConfig {
  id        String     @id @default(uuid())
  tenantId  String     @unique
  provider  AiProvider
  apiKeyEnc String     @db.Text
  model     String?    @db.VarChar(80) // override opcional do modelo padrão do provedor
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_ai_configs")
}

// ─── Chatwoot (histórico de conversas vinculado a Empresas/Pessoas) ──────────
// Ver docs/CHATWOOT_INTEGRATION_FEASIBILITY.md para o desenho completo.
// Diferente do TenantAiConfig, NÃO há fallback global via env — cada tenant
// tem sua própria conta Chatwoot, sem conta "padrão" compartilhada faria
// sentido aqui (token de terceiro de negócio, não uma feature best-effort).
enum ChatwootLinkMethod {
  MANUAL
  EMAIL
  PHONE
  ASSISTED
  UNLINKED
}

// Conexão do tenant com uma conta Chatwoot. apiTokenEnc/webhookSecretEnc nunca
// ficam em texto puro — mesmo padrão AES-256-GCM de TenantAiConfig/TenantSmtpConfig
// (ver src/lib/crypto.ts). webhookSecretEnc é o "webhook_secret" que o PRÓPRIO
// Chatwoot gera ao criar a inscrição de webhook (visível na UI/API dele) — o
// usuário cola esse valor na tela de configuração do Connect, que o usa para
// verificar a assinatura HMAC-SHA256 (X-Chatwoot-Signature) de cada evento recebido.
model ChatwootConnection {
  id               String    @id @default(uuid())
  tenantId         String
  baseUrl          String    @db.VarChar(255)
  accountId        String    @db.VarChar(40)
  apiTokenEnc      String    @db.Text
  webhookSecretEnc String    @db.Text
  active           Boolean   @default(true)
  lastSyncAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  contactLinks  ChatwootContactLink[]
  conversations ChatwootConversation[]
  webhookEvents ChatwootWebhookEvent[]
  syncRuns      ChatwootSyncRun[]

  // Um tenant pode ter mais de uma conta Chatwoot (ex: setores diferentes).
  @@unique([tenantId, accountId])
  @@index([tenantId])
  @@map("chatwoot_connections")
}

// Vínculo entre um contato do Chatwoot e uma Pessoa/Empresa do Connect. Campos
// prefixados chatwoot* são EXCLUSIVOS do Chatwoot — nunca reaproveitar
// Company.externalId (que já documenta outro propósito, sync com Acessorias)
// nem qualquer campo nativo de Empresa/Pessoa para guardar dado do Chatwoot.
model ChatwootContactLink {
  id                String             @id @default(uuid())
  tenantId          String
  connectionId      String
  chatwootContactId Int
  personId          String?
  companyId         String?
  chatwootName      String?            @db.VarChar(180) // nome exibido no Chatwoot — cache local pra listagem sem depender de vínculo
  chatwootEmail     String?            @db.VarChar(180)
  chatwootPhoneE164 String?            @db.VarChar(20)
  linkMethod        ChatwootLinkMethod @default(UNLINKED)
  linkConfidence    Int? // 0-100, null quando MANUAL/UNLINKED
  lastSyncAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  connection    ChatwootConnection     @relation(fields: [connectionId], references: [id])
  person        Person?                @relation(fields: [personId], references: [id])
  company       Company?               @relation(fields: [companyId], references: [id])
  conversations ChatwootConversation[]

  @@unique([tenantId, connectionId, chatwootContactId])
  @@index([tenantId, personId])
  @@index([tenantId, companyId])
  @@map("chatwoot_contact_links")
}

// Metadados de conversa — sincronizados via reconciliação periódica e webhook.
// assigneeLabel/teamLabel são texto livre (nome exibido no Chatwoot), não FK
// pra User: atendente/equipe do Chatwoot não necessariamente correspondem a um
// usuário do Connect, e acoplar os dois sistemas de identidade não é necessário
// para a v1 (somente leitura).
model ChatwootConversation {
  id                     String    @id @default(uuid())
  tenantId               String
  connectionId           String
  chatwootConversationId Int
  contactLinkId          String?
  inboxId                Int
  assigneeId             Int? // meta.assignee.id do Chatwoot — chave real pro vínculo com User (assigneeLabel é só nome de exibição)
  assigneeLabel          String?   @db.VarChar(120)
  teamLabel              String?   @db.VarChar(120)
  status                 String    @db.VarChar(30)
  priority               String?   @db.VarChar(20)
  labels                 Json?
  channel                String    @db.VarChar(60)
  lastActivityAt         DateTime?
  // Marcado quando o status transiciona PARA "resolved" (upsertConversation em
  // sync.ts); limpo se a conversa reabrir. Gatilho da Avaliação de Atendimentos
  // (ver ConversationEvaluation) — sem isso não daria pra saber quando o
  // atendimento realmente terminou (lastActivityAt reflete qualquer atividade).
  resolvedAt             DateTime?
  unreadCount            Int       @default(0)
  lastMessagePreview     String?   @db.VarChar(280)
  messageCount           Int? // total de mensagens do atendimento — calculado 1x via paginação da API (ver countAllMessages) e mantido por incremento no webhook message_created; null = ainda não calculado
  syncedAt               DateTime  @default(now())

  connection  ChatwootConnection      @relation(fields: [connectionId], references: [id])
  contactLink ChatwootContactLink?    @relation(fields: [contactLinkId], references: [id])
  messages    ChatwootMessage[]
  evaluation  ConversationEvaluation?

  @@unique([tenantId, connectionId, chatwootConversationId])
  @@index([tenantId, contactLinkId])
  @@index([tenantId, status, lastActivityAt])
  @@index([tenantId, resolvedAt])
  @@map("chatwoot_conversations")
}

// Corpo de mensagem — carregado sob demanda na primeira abertura de uma
// conversa (não replicado em massa na sincronização inicial, ver
// docs/CHATWOOT_INTEGRATION_FEASIBILITY.md seção 12) e mantido via webhook
// depois disso. attachments guarda só metadado + URL do Chatwoot, nunca o
// binário (decisão explícita: não replicar anexo sem necessidade comprovada).
model ChatwootMessage {
  id                String    @id @default(uuid())
  tenantId          String
  conversationId    String
  chatwootMessageId Int
  senderLabel       String?   @db.VarChar(120)
  senderType        String    @db.VarChar(30)
  messageType       String    @db.VarChar(20)
  contentType       String    @db.VarChar(30)
  content           String?   @db.Text
  isPrivate         Boolean   @default(false)
  attachments       Json?
  chatwootCreatedAt DateTime
  chatwootUpdatedAt DateTime?
  syncedAt          DateTime  @default(now())

  conversation ChatwootConversation @relation(fields: [conversationId], references: [id])

  @@unique([tenantId, conversationId, chatwootMessageId])
  @@index([tenantId, conversationId, chatwootCreatedAt])
  @@map("chatwoot_messages")
}

// Vínculo manual entre um agente do Chatwoot (chatwootAgentId, vem de
// meta.assignee.id) e um User do Connect 41 — mesmo padrão do
// Person.linkedUserId: associa a uma conta já existente, não gerencia
// login/permissões aqui (isso continua exclusivo de /admin/usuarios). Sem
// vínculo, o painel de Avaliação de Atendimentos agrupa pelo nome cru
// (chatwootAgentName).
model ChatwootAgentLink {
  id                String   @id @default(uuid())
  tenantId          String
  chatwootAgentId   Int
  chatwootAgentName String   @db.VarChar(120) // cache do nome, pro caso de renomeação no Chatwoot
  linkedUserId      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  linkedUser User?  @relation(fields: [linkedUserId], references: [id])

  @@unique([tenantId, chatwootAgentId])
  @@index([tenantId, linkedUserId])
  @@map("chatwoot_agent_links")
}

// Nota de 0-100 de um atendimento (1:1 com ChatwootConversation), gerada pela
// IA quando a conversa é resolvida (ver src/lib/chatwoot/evaluation.ts).
// Escrita+SLA apenas — CSAT foi cogitado e descartado (ver
// Backlog-Avaliacao-Atendimentos-2026-07-24.md no vault: o Chatwoot não expõe
// endpoint de pesquisa de satisfação, e uma pesquisa via mensagem livre
// esbarrava no Away Message nativo do Chatwoot disparando pro cliente ao
// responder fora do horário comercial).
model ConversationEvaluation {
  id             String   @id @default(uuid())
  tenantId       String
  conversationId String   @unique
  score          Int // 0-100 = writingScore + slaScore
  writingScore   Int // 0-50 — português/educação, avaliado pela IA
  slaScore       Int // 0-50 — tempo até 1ª resposta + até resolução
  reasoning      String   @db.Text // justificativa curta da IA, pra auditoria/transparência no drill-down
  evaluatedAt    DateTime @default(now())

  conversation ChatwootConversation @relation(fields: [conversationId], references: [id])

  @@index([tenantId, evaluatedAt])
  @@map("conversation_evaluations")
}

// Dedup de webhook — mesmo padrão de AlertDispatch (chave única evita
// processar o mesmo evento duas vezes, inclusive se o Chatwoot reenviar por
// timeout do nosso lado).
model ChatwootWebhookEvent {
  id              String    @id @default(uuid())
  tenantId        String
  connectionId    String
  eventType       String    @db.VarChar(60)
  externalEventId String    @db.VarChar(180)
  status          String    @db.VarChar(20) // RECEIVED | PROCESSED | FAILED
  attempts        Int       @default(0)
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  error           String?   @db.Text

  connection ChatwootConnection @relation(fields: [connectionId], references: [id])

  @@unique([tenantId, connectionId, externalEventId])
  @@index([tenantId, status])
  @@map("chatwoot_webhook_events")
}

// Registro de cada rodada de sincronização (inicial ou reconciliação) — mesmo
// espírito de observabilidade simples do resto do projeto (sem
// Prometheus/Grafana): consultável direto na tela de Integrações.
model ChatwootSyncRun {
  id             String    @id @default(uuid())
  tenantId       String
  connectionId   String
  type           String    @db.VarChar(20) // INITIAL | RECONCILIATION
  status         String    @db.VarChar(20) // RUNNING | COMPLETED | FAILED
  nextPage       Int       @default(1) // checkpoint de paginação — retomado entre chamadas HTTP (sem worker/fila, ver docs)
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  recordsRead    Int       @default(0)
  recordsCreated Int       @default(0)
  recordsUpdated Int       @default(0)
  recordsSkipped Int       @default(0)
  error          String?   @db.Text

  connection ChatwootConnection @relation(fields: [connectionId], references: [id])

  @@index([tenantId, connectionId, startedAt])
  @@map("chatwoot_sync_runs")
}

// Permissão de leitura por grupo de campo/documento sensível, por papel. Ausência
// de linha = negado por padrão (diferente do TenantModule, aqui o default é fechado).
model FieldPermission {
  id         String              @id @default(uuid())
  tenantId   String
  role       UserRole
  fieldGroup SensitiveFieldGroup
  canView    Boolean             @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, fieldGroup])
  @@map("field_permissions")
}

// Histórico salarial — reajustes e promoções do colaborador ao longo do tempo.
model SalaryChange {
  id             String   @id @default(uuid())
  tenantId       String
  personId       String
  previousSalary Decimal? @db.Decimal(12, 2)
  newSalary      Decimal  @db.Decimal(12, 2)
  changePercent  Decimal? @db.Decimal(5, 2)
  cargoId        String? // preenchido quando o reajuste é uma promoção com troca de cargo
  reason         String?  @db.Text
  effectiveDate  DateTime
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])
  cargo  Cargo? @relation(fields: [cargoId], references: [id])

  @@index([tenantId, personId])
  @@map("salary_changes")
}

model Vacation {
  id                     String         @id @default(uuid())
  tenantId               String
  personId               String
  acquisitivePeriodStart DateTime
  acquisitivePeriodEnd   DateTime
  concessivePeriodStart  DateTime?
  concessivePeriodEnd    DateTime?
  startDate              DateTime?
  returnDate             DateTime?
  days                   Int            @default(30)
  cashAllowance          Boolean        @default(false)
  installment            Boolean        @default(false)
  status                 VacationStatus @default(PLANEJADA)
  notes                  String?        @db.Text
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId, personId])
  @@map("vacations")
}

model Absence {
  id           String        @id @default(uuid())
  tenantId     String
  personId     String
  type         AbsenceType
  startDate    DateTime
  returnDate   DateTime?
  lostDays     Int?
  lostHours    Decimal?      @db.Decimal(6, 2)
  reason       String?       @db.Text
  shift        String?       @db.VarChar(60)
  location     String?       @db.VarChar(120)
  professional String?       @db.VarChar(120)
  status       AbsenceStatus @default(LANCADO)
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId, personId])
  @@map("absences")
}

model Termination {
  id          String            @id @default(uuid())
  tenantId    String
  personId    String
  type        TerminationType
  reason      String?           @db.Text
  status      TerminationStatus @default(SOLICITADO)
  requestedAt DateTime          @default(now())
  finalizedAt DateTime?
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId, personId])
  @@map("terminations")
}

// Competência de folha (mês/ano) por empresa — controle e conferência de
// lançamentos, não motor de cálculo trabalhista (decisão explícita).
model PayrollCompetency {
  id        String        @id @default(uuid())
  tenantId  String
  companyId String
  month     Int
  year      Int
  status    PayrollStatus @default(PENDENTE)
  openedAt  DateTime      @default(now())
  closedAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  company Company        @relation(fields: [companyId], references: [id])
  entries PayrollEntry[]

  @@unique([companyId, month, year])
  @@index([tenantId, companyId])
  @@map("payroll_competencies")
}

model PayrollEntry {
  id                  String        @id @default(uuid())
  tenantId            String
  competencyId        String
  personId            String
  grossSalary         Decimal       @db.Decimal(12, 2)
  workedDays          Int?
  vacationDays        Int?
  thirteenthSalary    Decimal?      @db.Decimal(12, 2)
  familyAllowance     Decimal?      @db.Decimal(12, 2)
  absenceDays         Int?
  missedDays          Int?
  overtimeHours       Decimal?      @db.Decimal(6, 2)
  nightShiftAllowance Decimal?      @db.Decimal(12, 2)
  hazardPay           Decimal?      @db.Decimal(12, 2)
  unhealthyPay        Decimal?      @db.Decimal(12, 2)
  benefitsTotal       Decimal?      @db.Decimal(12, 2)
  deductions          Decimal?      @db.Decimal(12, 2)
  status              PayrollStatus @default(PENDENTE)
  notes               String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  competency PayrollCompetency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  person     Person            @relation(fields: [personId], references: [id])

  @@unique([competencyId, personId])
  @@index([tenantId, personId])
  @@map("payroll_entries")
}

model OvertimeEntry {
  id             String         @id @default(uuid())
  tenantId       String
  personId       String
  date           DateTime
  expectedShift  String?        @db.VarChar(60)
  checkIn        DateTime?
  breakMinutes   Int?
  checkOut       DateTime?
  owedHours      Decimal?       @db.Decimal(5, 2)
  workedHours    Decimal?       @db.Decimal(5, 2)
  overtimeHours  Decimal?       @db.Decimal(5, 2)
  dayType        DayType        @default(UTIL)
  additionalRate Decimal?       @db.Decimal(5, 2)
  justification  String?        @db.Text
  status         OvertimeStatus @default(LANCADO)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId, personId, date])
  @@map("overtime_entries")
}

// Catálogo de benefícios por empresa.
model BenefitCatalog {
  id              String      @id @default(uuid())
  tenantId        String
  companyId       String
  name            String      @db.VarChar(120)
  type            BenefitType
  eligibilityRule String?     @db.Text
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments BenefitAssignment[]

  @@unique([companyId, name])
  @@index([tenantId, companyId])
  @@map("benefit_catalogs")
}

model BenefitAssignment {
  id            String        @id @default(uuid())
  tenantId      String
  personId      String
  benefitId     String
  companyValue  Decimal?      @db.Decimal(12, 2)
  discountValue Decimal?      @db.Decimal(12, 2)
  startDate     DateTime
  endDate       DateTime?
  status        BenefitStatus @default(ATIVO)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  person  Person         @relation(fields: [personId], references: [id])
  benefit BenefitCatalog @relation(fields: [benefitId], references: [id])

  @@index([tenantId, personId])
  @@map("benefit_assignments")
}

// Turno cadastrável por empresa (ex: "Comercial 08h-18h", "Turno Noite").
model WorkShift {
  id        String   @id @default(uuid())
  tenantId  String
  companyId String
  name      String   @db.VarChar(80)
  startTime String   @db.VarChar(5) // "HH:MM"
  endTime   String   @db.VarChar(5)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries ScheduleEntry[]

  @@unique([companyId, name])
  @@index([tenantId, companyId])
  @@map("work_shifts")
}

// Feriado — cadastro tenant-wide (não por empresa; feriado nacional/estadual/municipal
// vale igual pra todos os clientes do tenant).
model Holiday {
  id        String   @id @default(uuid())
  tenantId  String
  date      DateTime
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("holidays")
}

model ScheduleEntry {
  id        String         @id @default(uuid())
  tenantId  String
  personId  String
  shiftId   String?
  date      DateTime
  startTime String?        @db.VarChar(5)
  endTime   String?        @db.VarChar(5)
  dayOff    Boolean        @default(false)
  isHoliday Boolean        @default(false)
  status    ScheduleStatus @default(PLANEJADA)
  notes     String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  person Person     @relation(fields: [personId], references: [id])
  shift  WorkShift? @relation(fields: [shiftId], references: [id])

  @@index([tenantId, personId, date])
  @@map("schedule_entries")
}

// Catálogo de treinamentos — tenant-wide (compartilhado entre empresas do tenant).
model Training {
  id             String   @id @default(uuid())
  tenantId       String
  name           String   @db.VarChar(150)
  description    String?  @db.Text
  workloadHours  Decimal? @db.Decimal(5, 2)
  validityMonths Int?
  active         Boolean  @default(true)
