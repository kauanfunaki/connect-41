  updatedAt   DateTime @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  scores EvaluationScore[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("competencies")
}

model EvaluationCycle {
  id        String    @id @default(uuid())
  tenantId  String
  name      String    @db.VarChar(120)
  startDate DateTime
  endDate   DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  evaluations Evaluation[]

  @@index([tenantId])
  @@map("evaluation_cycles")
}

model Evaluation {
  id                  String    @id @default(uuid())
  tenantId            String
  cycleId             String
  personId            String
  evaluatorUserId     String
  evaluationDate      DateTime  @default(now())
  averageScore        Decimal?  @db.Decimal(4, 2)
  notes               String?   @db.Text
  developmentPlan     String?   @db.Text
  improvementDeadline DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  cycle     EvaluationCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  person    Person            @relation(fields: [personId], references: [id])
  evaluator User              @relation(fields: [evaluatorUserId], references: [id])
  scores    EvaluationScore[]

  @@unique([cycleId, personId])
  @@index([tenantId, personId])
  @@map("evaluations")
}

model EvaluationScore {
  id           String   @id @default(uuid())
  tenantId     String
  evaluationId String
  competencyId String
  score        Decimal  @db.Decimal(4, 2)
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id])

  @@unique([evaluationId, competencyId])
  @@index([tenantId, evaluationId])
  @@map("evaluation_scores")
}

// Parecer estruturado de entrevista (scorecard) — um por entrevistador por
// candidatura. Diferente de Evaluation (desempenho de colaborador, via catálogo
// de Competency): aqui os critérios são fixos e simples (1-5), o foco é a
// decisão de avançar o candidato no funil. O consolidado (média + tally de
// recomendações) é calculado na leitura a partir dos scorecards de todos os
// entrevistadores.
model InterviewScorecard {
  id              String                  @id @default(uuid())
  tenantId        String
  candidaturaId   String
  evaluatorUserId String
  stage           RecruitmentStage? // etapa em que a entrevista aconteceu (contexto)
  comunicacao     Int? // 1-5
  tecnico         Int? // 1-5
  fitCultural     Int? // 1-5
  experiencia     Int? // 1-5
  recommendation  InterviewRecommendation @default(TALVEZ)
  notes           String?                 @db.Text
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  candidatura Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)
  evaluator   User        @relation(fields: [evaluatorUserId], references: [id])

  @@unique([candidaturaId, evaluatorUserId])
  @@index([tenantId, candidaturaId])
  @@map("interview_scorecards")
}

// ─── Cross-setor ──────────────────────────────────────────────────────────────

// Transferência entre setores no formato do dia a dia (Acessórias): informações
// gerais (message/description) valem pra todos os setores de destino, e cada
// setor recebe a própria instrução em HandoffSector — uma transferência só,
// em vez de uma por setor.
model Handoff {
  id          String          @id @default(uuid())
  tenantId    String
  fromSector  String          @db.VarChar(40)
  entityType  EntityType
  entityId    String
  requestedBy String
  message     String?         @db.Text
  description String?         @db.Text
  priority    HandoffPriority @default(MEDIUM)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  requester User            @relation("HandoffRequester", fields: [requestedBy], references: [id])
  views     HandoffView[]
  sectors   HandoffSector[]

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("handoffs")
}

// Instrução da transferência para UM setor de destino — cada setor tem seu
// próprio status, instrução e responsável (designado pela coordenação do
// setor, sempre entre membros do próprio setor).
model HandoffSector {
  id          String              @id @default(uuid())
  tenantId    String
  handoffId   String
  sectorCode  String              @db.VarChar(40)
  instruction String?             @db.Text
  status      HandoffSectorStatus @default(NEW)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  handoff  Handoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)
  assignee User?   @relation("HandoffSectorAssignee", fields: [assignedTo], references: [id])

  @@unique([handoffId, sectorCode])
  @@index([tenantId, sectorCode, status])
  @@map("handoff_sectors")
}

// Registro de quem visualizou o detalhe de uma transferência — @@unique
// garante idempotência (marcar como visto em toda visita não gera duplicata,
// só atualiza viewedAt).
model HandoffView {
  id        String   @id @default(uuid())
  tenantId  String
  handoffId String
  userId    String
  viewedAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  handoff Handoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([handoffId, userId])
  @@index([tenantId])
  @@map("handoff_views")
}

// Trilha de auditoria — quem fez o quê, quando. Somente leitura pela UI
// (/admin/auditoria, restrito a SUPER_ADMIN); nunca editável ou excluível
// pelo app. Best-effort: falha ao gravar log nunca deve derrubar a ação real.
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String   @db.VarChar(60) // ex: "company.create", "sector.update"
  entityType String?  @db.VarChar(40) // livre (Company, Person, Sector, Tag...) — não usa o enum EntityType, que só cobre Company/Person
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id         String      @id @default(uuid())
  tenantId   String
  userId     String
  type       String      @db.VarChar(60) // ex: HANDOFF_RECEIVED, MENTION, STAGE_OVERDUE
  entityType EntityType?
  entityId   String?
  message    String      @db.VarChar(255)
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, read])
  @@map("notifications")
}

// Assinatura de push do navegador (Web Push API) — um usuário pode ter mais
// de uma (várias abas/dispositivos). `endpoint` já é a chave natural de
// idempotência: o navegador reusa o mesmo endpoint pra resubscribe.
model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("push_subscriptions")
}

// Admissão digital self-service — link tokenizado que o novo colaborador
// (em ADMISSAO_EM_ANDAMENTO) abre SEM login para preencher os próprios dados
// e enviar documentos, alimentando a ficha e eliminando a digitação manual do
// DP. Mesmo padrão de token público do ClientDocumentRecipient. O submit grava
// direto no Person/Document; este model é só o gate + rastreio do estado.
model AdmissaoLink {
  id          String             @id @default(uuid())
  tenantId    String
  personId    String
  token       String             @unique @db.VarChar(64)
  status      AdmissaoLinkStatus @default(PENDENTE)
  expiresAt   DateTime
  submittedAt DateTime?
  createdById String
  createdAt   DateTime           @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([tenantId, personId])
  @@map("admissao_links")
}

// Dependente de um colaborador (IRRF, salário-família, plano de saúde). Coletado
// na admissão digital e usado depois pela geração do eSocial S-2200 (grupo de
// dependentes) — os flags isIRDependent/isSalarioFamilia são os campos que o
// cálculo trabalhista de cada empresa-cliente realmente consome.
model Dependente {
  id               String                 @id @default(uuid())
  tenantId         String
  personId         String
  name             String                 @db.VarChar(180)
  cpf              String?                @db.VarChar(14)
  birthDate        DateTime?
  relationship     DependenteRelationship @default(OUTRO)
  isIRDependent    Boolean                @default(false)
  isSalarioFamilia Boolean                @default(false)
  createdAt        DateTime               @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([tenantId, personId])
  @@map("dependentes")
}

// Frequência de uma RecurringObligation. MONTHLY é o padrão histórico (usa
// dayOfMonth); DAILY roda todo dia útil; WEEKLY/BIWEEKLY usam dayOfWeek
// (1=segunda..7=domingo) — BIWEEKLY só dispara nas semanas de paridade par
// contadas a partir de uma época fixa (ver WEEK_EPOCH em recurringObligations.ts).
enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// Obrigação recorrente de uma empresa-cliente (DAS, DCTF, folha, férias
// coletivas, título bancário diário, contas a receber semanais...) — o
// scheduler interno (src/lib/recurringObligations.ts) gera um item de kanban
// no pipeline do setor por período (dia/semana/quinzena/mês conforme a
// frequência), com vencimento prorrogado para o próximo dia útil quando cai
// em fim de semana/feriado. Dedup por período via AlertDispatch (chave
// OBLIGATION:{id}:{periodo}, onde periodo varia por frequência).
model RecurringObligation {
  id            String             @id @default(uuid())
  tenantId      String
  companyId     String
  sectorCode    String             @db.VarChar(40)
  pipelineId    String
  title         String             @db.VarChar(160)
  description   String?            @db.Text
  frequency     RecurringFrequency @default(MONTHLY)
  dayOfMonth    Int? // 1..31 — obrigatório quando frequency = MONTHLY; meses mais curtos usam o último dia
  dayOfWeek     Int? // 1..7 (segunda..domingo) — obrigatório quando frequency = WEEKLY ou BIWEEKLY
  responsibleId String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  responsible User?    @relation(fields: [responsibleId], references: [id])

  @@index([tenantId, active])
  @@map("recurring_obligations")
}

// Dedup do motor de alertas (cron externo, ver src/lib/alerts.ts) — evita
// notificar a mesma condição mais de uma vez no mesmo dia mesmo que o job
// rode várias vezes (ex: scheduler externo chamando a cada 15min). sentOn é
// sempre meia-noite UTC do dia do disparo; a unicidade é por tenant+chave+dia.
model AlertDispatch {
  id        String   @id @default(uuid())
  tenantId  String
  alertKey  String   @db.VarChar(160) // ex: "VACATION_EXPIRING:{vacationId}"
  sentOn    DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, alertKey, sentOn])
  @@index([tenantId, sentOn])
  @@map("alert_dispatches")
}

// ─── Reuniões (Fase M) ────────────────────────────────────────────────────────

enum MeetingProvider {
  GOOGLE
  MICROSOFT
}

// Conexão OAuth de um usuário com Google ou Microsoft — só coordenadores
// (SECTOR_ADMIN) e admins conectam a própria conta (gate na Server Action, não
// aqui). accessToken/refreshToken nunca são lidos no client, só em Server
// Actions/Route Handlers.
model OAuthAccount {
  id           String          @id @default(uuid())
  tenantId     String
  userId       String
  provider     MeetingProvider
  accountEmail String?         @db.VarChar(160)
  accessToken  String          @db.Text
  refreshToken String          @db.Text
  expiresAt    DateTime
  scope        String?         @db.VarChar(255)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([tenantId])
  @@map("oauth_accounts")
}

// Reunião agendada via Google Meet ou Microsoft Teams — vinculada a um item do
// Kanban (pipelineItemId) e/ou à agenda própria de um setor (sectorCode),
// conforme decisão do levantamento (as duas formas não são exclusivas).
model Meeting {
  id              String          @id @default(uuid())
  tenantId        String
  provider        MeetingProvider
  title           String          @db.VarChar(180)
  meetingUrl      String          @db.VarChar(500)
  externalEventId String          @db.VarChar(255)
  startAt         DateTime
  endAt           DateTime
  pipelineItemId  String?
  sectorCode      String?         @db.VarChar(40)
  companyId       String? // empresa associada — reunião criada pela Agenda, sem item de Kanban
  candidaturaId   String? // entrevista de recrutamento — reunião vinculada à candidatura, sem depender de pipelineItem
  clientName      String?         @db.VarChar(255) // nome(s) do(s) participante(s)/cliente(s), texto livre
  createdByUserId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  pipelineItem PipelineItem?     @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  candidatura  Candidatura?      @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("MeetingCreatedBy", fields: [createdByUserId], references: [id])
  attendees    MeetingAttendee[]

  @@index([tenantId, pipelineItemId])
  @@index([tenantId, sectorCode, startAt])
  @@index([tenantId, companyId])
  @@index([tenantId, candidaturaId])
  @@map("meetings")
}

// Responsáveis/participantes da reunião — só usuários com acesso à
// plataforma (não convidados externos, que entram só pelo link do
// Meet/Teams).
model MeetingAttendee {
  meetingId      String
  userId         String
  createdAt      DateTime  @default(now())
  // Ciência do alerta focal de reunião — null = o bloco centralizado ainda
  // aparece pro usuário quando a reunião estiver próxima; preenchido no "OK".
  acknowledgedAt DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
  @@map("meeting_attendees")
}

// Repositório de Senhas do BPO — centraliza credenciais que hoje ficam
// espalhadas em .txt (login de portais, bancos, sistemas de clientes).
// Empresa é opcional (permite credencial geral do setor, sem cliente
// específico). Senha nunca em texto puro — mesmo padrão de criptografia de
// TenantSmtpConfig.passwordEnc (ver src/lib/crypto.ts).
model BpoCredential {
  id          String   @id @default(uuid())
  tenantId    String
  companyId   String?
  title       String   @db.VarChar(120)
  username    String?  @db.VarChar(180)
  passwordEnc String   @db.Text
  url         String?  @db.VarChar(255)
  notes       String?  @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  company   Company?            @relation(fields: [companyId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  views     BpoCredentialView[]

  @@index([tenantId, companyId])
  @@map("bpo_credentials")
}

// Auditoria de acesso — quem revelou/copiou a senha e quando. Não impede
// acesso de ninguém do setor, só dá rastreabilidade (informação sensível).
model BpoCredentialView {
  id           String   @id @default(uuid())
  tenantId     String
  credentialId String
  userId       String
  viewedAt     DateTime @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  credential BpoCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id])

  @@index([credentialId])
  @@map("bpo_credential_views")
}
