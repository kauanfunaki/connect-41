# Connect 41 — variáveis de ambiente
# Copie este arquivo para `.env` e preencha. NUNCA commite o .env real.

# --- Banco de dados (MySQL via Prisma) ---
# Produção: host vps.41tech.cloud, porta 3309
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL="mysql://usuario:senha@vps.41tech.cloud:3309/connect_41"

# --- Autenticação (JWT) ---
# Gere segredos fortes e distintos (ex.: openssl rand -base64 48). Não reutilize.
JWT_ACCESS_SECRET="defina-um-segredo-forte"
JWT_REFRESH_SECRET="defina-outro-segredo-forte"

# Tempo de expiração dos tokens
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Seed (só usado por `npm run seed`) ---
# Senha inicial do admin criado pelo seed. Obrigatória (>= 12 caracteres).
# Nunca commitar o valor real. O seed NÃO reseta a senha de um admin já existente.
SEED_ADMIN_PASSWORD="defina-uma-senha-inicial-forte"

# --- Integração com o 41-Tech-Hub ---
# Usado pela tela de login (Esqueci a senha / Solicitar acesso) para abrir um
# chamado real no Hub em nome de quem ainda não tem acesso ao Connect 41.
# Token de serviço gerado no Hub (rota POST /api/integrations/connect41/access-requests).
HUB_API_URL="https://hub.41tech.cloud"
HUB_SERVICE_TOKEN="defina-um-token-de-servico-forte"

# --- Reuniões: Google Calendar/Meet (OAuth2) ---
# Criar em https://console.cloud.google.com/apis/credentials — tipo "Web application".
# Redirect URI precisa bater exatamente com o cadastrado no Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://useconnect.com.br/api/integrations/google/callback"

# --- Reuniões: Microsoft Teams/Outlook (OAuth2 via Azure AD / Microsoft Graph) ---
# Criar em https://portal.azure.com — App registrations. Redirect URI precisa
# bater exatamente com o cadastrado no Azure. MICROSOFT_TENANT_ID é opcional
# ("common" cobre contas pessoais + de organização).
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="https://useconnect.com.br/api/integrations/microsoft/callback"
MICROSOFT_TENANT_ID="common"

# --- Documentos para Clientes: criptografia da senha SMTP por tenant ---
# Gere um segredo forte (ex.: openssl rand -base64 48). Trocar este valor
# invalida a senha SMTP já salva de todos os tenants (precisam recadastrar).
SECRETS_ENCRYPTION_KEY="defina-um-segredo-forte"

# --- URL pública do app ---
# Fonte canônica do domínio público: usada nos links enviados por e-mail
# (https://SEU_DOMINIO/d/{token}) e nos redirects pós-OAuth das integrações.
# Ao trocar de domínio, atualize esta env + os redirect URIs acima + o
# cadastro no Google Cloud Console e no Azure.
APP_PUBLIC_URL="https://useconnect.com.br"

# --- IA (Claude/Anthropic ou OpenAI) ---
# Fallback global usado só por tenants que NÃO configuraram a própria chave em
# Integrações → Inteligência Artificial (tela em /admin/integracoes, tela
# tenant-scoped e criptografada em banco — ver TenantAiConfig). Sem chave
# alguma (nem aqui, nem por tenant), os botões de IA aparecem mas retornam erro
# amigável. Gere em https://console.anthropic.com ou https://platform.openai.com.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- Motor de alertas proativos (cron externo, ex: n8n) ---
# Protege POST /api/cron/alerts, chamado por um scheduler externo sem sessão
# de usuário (autenticação própria via Bearer token, não pelo JWT do proxy).
# Gere um token forte e configure o mesmo valor no scheduler externo.
CRON_SERVICE_TOKEN="defina-um-token-de-servico-forte"
